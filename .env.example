# 콘솔에서 해당 앱의 「카카오맵」등 OPEN_MAP_AND_LOCAL(지도·로컬) 사용을 ON 해야 합니다.
# (비활성 시 NotAuthorizedError: disabled OPEN_MAP_AND_LOCAL)

# Kakao Developers → 내 애플리케이션 → 앱 키
# 플랫폼 키 → JavaScript 키 → JavaScript SDK 도메인 등록:
#   http://localhost:5173  (127.0.0.1로 열면 동일하게 http://127.0.0.1:5173 도 추가)

VITE_KAKAO_JAVASCRIPT_KEY=

# 카카오 로그인 → 리다이렉트 URI와 동일 (authorize·토큰 교환에 사용, 문자 단위로 일치)
# 예: http://localhost:5173/  또는 http://localhost:5173/account
# 미입력 시: http://localhost:5173/  (루트로 콘솔에 등록해도 로그인 성공 후 앱은 /account 로 이동)
VITE_KAKAO_REDIRECT_URI=

# REST API 키(JavaScript 키 아님) — 지도 프록시 Authorization + 토큰 교환 client_id
# /kakao-oauth/token 401 → 이 값이 콘솔의「REST API 키」와 같은지 확인(다른 탭의 JS 키 넣지 않기)
KAKAO_REST_API_KEY=

# 카카오 로그인 → [보안] 클라이언트 시크릿 코드 「사용함」일 때만 필수.
# - 이 값은 VITE_ 로 시작하지 않게 두세요(번들에 들어가면 누구나 볼 수 있음).
# - 로컬: 아래 한 줄을 .env 에 넣고 npm run dev 재시작.
# - Vercel: Environment Variables 에 KAKAO_CLIENT_SECRET 추가.
# - Supabase OAuth 로만 로그인할 때: 시크릿은 Supabase 대시보드 → Auth → Providers → Kakao 의 Client Secret 에 넣고,
#   프론트 .env에는 넣지 않아도 됩니다(레거시 JS SDK + /kakao-oauth 토큰 교환 경로를 쓸 때만 아래 필요).
KAKAO_CLIENT_SECRET=

# --- Vercel 배포 시 ---
# VITE_* 는 빌드에 박히므로 Production·Preview 환경에도 넣고 재배포 필요.
# KAKAO_REST_API_KEY / KAKAO_CLIENT_SECRET 은 서버(개발 미들웨어, api/kakao-oauth-token)에서만 사용.

# --- Supabase (선택) URL·anon key 가 있으면 카카오 로그인은 Supabase Auth OAuth 로 전환 ---
# Supabase Dashboard → Authentication → Providers → Kakao 활성화
# Redirect URL 에 Vercel 도메인·로컬 origin 등록, 카카오 개발자 콘솔 Redirect URI 에
#   https://<project-ref>.supabase.co/auth/v1/callback
# 포함
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
